{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxlint-config-json-schema/latest/schema.json",
  "rules": {
    "eqeqeq": "warn",
    "no-console": "warn",
    "no-debugger": "error",
    "no-alert": "warn",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-unused-vars": [
      "warn",
      {
        "varsIgnorePattern": "^_",
        "argsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_"
      }
    ]
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "*.config.*",
    "drizzle/migrations/**"
  ]
}
